{
  "name": "architect",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env ENV=development vite",
    "build": "cross-env ENV=production vite build",
    "preview": "cross-env ENV=development vite preview",
    "test": "vitest",
    "engine": "npm run generate-animations && cross-env NODE_OPTIONS=\"--loader ts-node/esm\" ts-node ./engine/index.ts",
    "optimize-glb": "node ./tools/optimizeGLB.js",
    "generate-animations": "node ./tools/animation/_generate.js",
    "generate-brotli": "node ./tools/generateBrotli.js",
    "asset-packer": "node ./tools/assetPacker/assetPackerServer.js",
    "build-assets": "node ./tools/assetPacker/assetPackerCLI.js",
    "install-blender-addon": "node ./tools/project_architect_blender/install.js"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@gltf-transform/extensions": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "draco3dgltf": "^1.5.7",
    "events": "^3.3.0",
    "gl-matrix": "^3.4.3",
    "i": "^0.3.7",
    "midi-file": "^1.2.4",
    "npm": "^11.1.0",
    "potpack": "^2.1.0",
    "react": "^17.0.0",
    "react-dom": "^17.0.0",
    "react-inlinesvg": "^4.1.8",
    "react-router-dom": "^6.21.1",
    "sharp": "^0.33.5",
    "three": "^0.171.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.2.1",
    "@types/brotli": "^1.3.4",
    "@types/cors": "^2.8.17",
    "@types/draco3dgltf": "^1.4.3",
    "@types/express": "^5.0.0",
    "@types/node": "^20.13.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/three": "^0.169.0",
    "@types/ws": "^8.18.1",
    "@webgpu/types": "^0.1.65",
    "brotli": "^1.3.3",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "fbx2gltf": "^0.9.7-p1",
    "rollup-plugin-ignore": "^1.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^6.3.4",
    "vite-bundle-analyzer": "^1.3.7",
    "vite-plugin-checker": "^0.6.4",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^3.1.2"
